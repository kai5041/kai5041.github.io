  <script>
    (function () {
      const supported_languages = ["en", "ja", "it", "ro"];
      const fallback_language = "en";

      const lang = navigator.language || navigator.userLanguage;
      const short = lang.toLowerCase().split("-")[0];

      const chosen = supported_languages.includes(short) ? short : fallback_language;

      window.location.replace("/" + chosen + "/services");
    })();
  </script>

  <noscript>
    <meta http-equiv="refresh" content="0; url=/en/services">
  </noscript>

