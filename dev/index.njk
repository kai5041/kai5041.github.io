---
layout: base.njk
title_id: home
---

<style>
.hero {
  text-align: center;
  font-size: 1.5rem;
  margin-bottom: 4vh;
}

.logo {
  font-size: 3rem;
  font-family: "Noto Serif JP", serif;
}

.selector {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2vh;
  width: 70vw;
  max-width: 900px;
  margin: 0 auto;
}

.selector div {
  display: flex;
  flex-direction: column;
  justify-content: space-between;

  min-height: 180px;

  border: 4px solid var(--black);
  padding: 2vh 2vw;
  box-sizing: border-box;

  text-align: center;
}

@media (max-width: 768px) {
  .selector {
    grid-template-columns: 1fr;
    width: 75vw;
  }

  .selector div {
    padding: 4vh 6vw;
  }

  .selector div a {
    margin-top: 2vh;
  }
}

.cta {
  margin-top: auto;

  padding: 1vh 2vw;
  display: inline-block;

  background-color: var(--white);
  color: var(--black);
  text-decoration: none;
  font-weight: 600;

  text-align: center;
}

.right {
  background-color: var(--black);
  color: var(--white);
}

.left .cta {
  background-color: var(--black);
  color: var(--white);
}

.selector p {
  font-size: 1.1rem;
}
</style>

<main>

<div class="hero">
  <p class="logo">Kai/解</p>
  <p class="tagline">{{ index.tagline | t(lang) }}</p>
</div>

<div class="selector">
  <div class="left">
    <p>{{ index.tile1 | t(lang) }}</p>
    <a class="cta" href="/{{ lang }}/services">{{ index.tile1.cta | t(lang) }}</a>
  </div>

  <div class="right">
    <p>Open-source projects created and maintained by the operator.</p>
    <a class="cta" href="/{{ lang }}/projects">{{ global.project_index | t(lang) }}</a>
  </div>
</div>
</main>


