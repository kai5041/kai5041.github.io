---
title: home
layout: layout.njk
---

<style>
  :root {
    --radius: 14px;
  }

  main {
    max-width: 80rem;
    margin-inline: auto;
    padding: 3rem 1.5rem;
  }

  .hero {
    width: 100%;
    padding: 3rem 2rem;
    font-size: 1.5rem;
    color: var(--bgc);
    background: var(--fgc);
    border-radius: var(--radius);
  }

  .hero div {
    max-width: 70rem;
    margin-inline: auto;
    text-align: center;
  }

  .hero a {
    color: var(--bgc);
    text-underline-offset: 3px;
  }

  .hero p {
    margin: 0.4rem 0;
  }

  section:last-of-type {
    display: grid;
    gap: 1.5rem;
  }

  .offer {
    border: 1px solid var(--fgc);
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem;
  }

  .offer-title {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
  }

  .offer p {
    margin: 0.5rem 0;
    line-height: 1.5;
  }

  .offer > a {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.4rem 0.75rem;

    font-weight: 600;
    text-decoration: none;

    color: var(--bgc);
    background-color: var(--fgc);

    border: 1px solid var(--fgc);
    border-bottom: 6px solid var(--neon-green);
    border-radius: 8px;

    transition:
      color 0.2s ease-in-out,
      background-color 0.2s ease-in-out,
      border-color 0.2s ease-in-out;
  }

  .offer > a:hover {
    color: var(--fgc);
    background-color: var(--bgc);
  }

  .price {
    margin-top: 0.75rem;
    padding-top: 0.75rem;

    font-size: 0.95rem;
    opacity: 0.85;

    border-top: 1px solid var(--fgc);
  }

  section p a {
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  .small {
    font-size: 1rem;
  }

  @media (max-width: 700px) {
    main {
      padding: 2rem 1rem;
    }

    .hero {
      padding: 2rem 1.25rem;
      font-size: 1.25rem;
    }

    .offer {
      padding: 1.25rem;
    }
  }
</style>

<main>

  <section class="hero">
    <div>
      <p><strong><em>{{ index.hero | t(lang) | safe }}</em></strong></p>
    </div>
  </section>

  <section>
    {% for offer in index.offers | t(lang) %}
    <div class="offer">

      <h3 class="offer-title">❖ {{ offer.title }}</h3>

      <p>{{ offer.description | safe }}</p>

      {% if offer.result %}
      <p><strong>{{ offer.result }}</strong></p>
      {% endif %}

      <p class="price">{{ offer.pricing | safe }}</p>

      <a href="/{{ lang }}/contact/">▸ {{ offer.cta }}</a>

    </div>
    {% endfor %}
  </section>

  {% note global.note, lang, index.currency_note %}

  <!--
  <section>
    <h3>{{ index.lr | t(lang) }}</h3>
    <p>{{ global.coming_soon | t(lang) }}</p>
  </section>
  -->

</main>