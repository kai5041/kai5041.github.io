---
title: home
layout: layout.njk
---

<style>
  :root {
    --radius: 14px;
  }

  main {
    padding: 3rem 1.5rem;
  }

  .hero {
    font-size: 1.5rem;
    width: 100%;
    background: var(--fgc);
    color: var(--bgc);
    padding: 3rem 2rem;
    border-radius: var(--radius);
  }

  .hero div {
    margin: 0 auto;
    text-align: center;
  }

  .hero a {
    color: var(--bgc);
    text-underline-offset: 3px;
  }

  .hero p {
    margin: 0.4rem 0;
  }

  .offer {
    border: 1px solid var(--fgc);
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem;
    margin-bottom: 2vh;
  }

  .offer-title {
    margin: 0 0 0.5rem 0;
    font-size: 1.2rem;
  }

  .offer p {
    margin: 0.5rem 0;
    line-height: 1.5;
  }

  .offer a {
    display: inline-block;
    margin-top: 1rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--bgc);
    background-color: var(--fgc);
    border: 1px solid var(--fgc);
    border-radius: 8px;
    padding: 0.4rem 0.75rem;
    transition: 0.2s ease-in-out;
  }

  .offer a:hover {
    color: var(--fgc);
    background-color: var(--bgc);
  }

  .price {
    font-size: 0.95rem;
    opacity: 0.85;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--fgc);
  }

  section a {
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  @media (max-width: 700px) {
    .hero {
      padding: 2rem 1.25rem;
    }

    .offer {
      padding: 1.25rem;
    }
  }

  .small {
    font-size: 1rem;
  }
</style>

<main>

  <section class="hero">
    <div>
      <p><strong>{{ index.hero | t(lang) }}</strong></p>
      <p>Solving technical problems and building software.</p>
    </div>
  </section>

  <section>
    <hr>
    <h2>What I can help with</h2>
    <br>
    {% for offer in index.offers | t(lang) %}
    <div class="offer">

      <h3 class="offer-title">❖ {{ offer.title }}</h3>

      <p>{{ offer.description | safe }}</p>

      {% if offer.result %}
      <p><strong>{{ offer.result }}</strong></p>
      {% endif %}

      <p class="price">{{ offer.pricing | safe }}</p>

      <a href="/{{ lang }}/contact/">▸ {{ offer.cta }}</a>

    </div>
    {% endfor %}
  </section>

  {% note global.note, lang, index.currency_note %}

  <!--
    <section>
      <h3>{{ index.lr | t(lang) }}</h3>
      <p>{{ global.coming_soon | t(lang) }}</p>
    </section>
  -->

</main>
