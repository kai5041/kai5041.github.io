---
title: home
layout: layout.njk
---

<style>
  :root {
    --radius: 14px;
  }

  main {
    padding: 3rem 1.5rem;
  }

  .hero {
    font-size: 1.5rem;
    width: 100%;
    background: var(--fgc);
    color: var(--bgc);
    padding: 3rem 2rem;
    border-radius: var(--radius);
  }

  .hero div {
    margin: 0 auto;
    text-align: center;
  }

  .hero a {
    color: var(--bgc);
    text-underline-offset: 3px;
  }

  .offer {
    border: 1px solid var(--fgc);
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem;
    margin-bottom: 2vh;
  }

  .offer p {
    margin: 0.5rem 0;
    line-height: 1.5;
  }

  .offer strong {
    font-size: 1.15rem;
  }

  .offer a {
    display: inline-block;
    margin-top: 0.75rem;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }

  section a {
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  @media (max-width: 700px) {
    .hero {
      padding: 2rem 1.25rem;
    }

    .offer {
      padding: 1.25rem;
    }
  }

  .hero p {
    margin: 0.4rem 0;
  }

  .small {
    font-size: 1rem;
  }
</style>

<main>

  <section class="hero">
    <div>
      <p>{{ index.hero | t(lang) }}</p>
    </div>
  </section>

  <section>
    {% for offer in index.offers | t(lang) %}
    <div class="offer">
      <p>❖ <strong>{{ offer.title }}</strong></p>

      <p>{{ offer.description }}</p>

      <p class="small">{{ offer.pricing }}</p>

      <a href="/{{ lang }}/contact/">▸ {{ offer.cta }}</a>
    </div>
    {% endfor %}

  </section>

  {% note global.note, lang, index.currency_note %}

  <section>
    <h3>{{ index.lr | t(lang) }}</h3>
    <p>{{ global.coming_soon | t(lang) }}</p>
  </section>

</main>