<style>
  .clickable {
    text-decoration: underline;
    cursor: pointer;
    user-select: none;
    margin-top: 1rem;
  }

  .clickable::after {
    content: "→";
    margin-left: 0.5em;
    display: inline-block;
  }

  .hidden {
    display: none;
  }

  .hidden.open {
    display: block;
  }

  #services-list,
  #services-list ul {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }

  #services-list li {
    max-width: 100%;
  }

  #services-list ul {
    padding-left: 1.25rem;
  }

  #services-list .hidden div p {
    margin: 0.2rem 0;
  }

  #services-list .hidden ul {
    margin: 0 0 0.6rem 1.2rem;
  }

  #services-list .hidden ul {
    list-style: disc;
  }

  #services-list .hidden strong {
    display: inline-block;
    margin-top: 0.4rem;
  }

  .cta {
    text-align: center;
    margin-top: 1rem;
  }
</style>

<main>

