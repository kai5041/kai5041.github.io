  <script>
    document.querySelectorAll(".clickable").forEach(el => {
      el.addEventListener("click", () => {
        const next = el.nextElementSibling;

        if (next && next.classList.contains("hidden")) {
          next.classList.toggle("open");
          el.classList.toggle("open");
        }
      });
    });
  </script>

  <hr>

