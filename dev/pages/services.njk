---
title: services
layout: layout.njk
---

<style>
  h1 {
    text-align: center;
    margin-bottom: 2vh;
  }

  section.cards {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
  }

  .card {
    background-color: var(--bgc-soft);
    flex: 1 1 260px;
    max-width: 320px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    text-align: center;
    min-height: 260px;
  }

  .card .container {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  h2 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .card p {
    opacity: 0.8;
    margin-bottom: 1rem;
  }

  .bottom {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .details-trigger {
    text-decoration: underline;
    opacity: 0.6;
    cursor: pointer;
    transition: opacity 150ms ease;
  }

  .details-trigger:hover {
    opacity: 1;
  }

  h1 {
    text-align: center;
    margin-bottom: 2vh;
  }
</style>

<main>

  <section>
    <h1>{{ services.title | t(lang) }}</h1>
  </section>

  <!-- SERVICES GRID -->
  <section class="cards">

    <div class="card">
