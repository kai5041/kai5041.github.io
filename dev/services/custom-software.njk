---
layout: base.njk
title_id: custom_software
---

<link rel="stylesheet" href="/css/services.css">

{% for offerId, offer in offers.offers %}

<section class="offer" id="{{ offerId }}">
  <h2>{{ offer.title }}</h2>

  <div>
    <p class="includes"><strong>Includes:</strong></p>
    <ul>
      {% for item in offer.includes %}
        <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </div>

  <div>
    <p><strong>Features increasing price:</strong></p>
    <ul>
      {% for item in offer.features_increasing_price %}
        {% if item == "LANG_PRICE_NOTE" %}
          <li>
            +{{ services["custom_sw_lang"] | t(lang) | safe }}
            per user-visible output event (printf, log, warn, error),
            per supported language (Italian, Romanian, Japanese)
          </li>
        {% else %}
          <li>{{ item }}</li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>

  <div>
    <p class="excludes"><strong>Excludes:</strong></p>
    <ul>
      {% for item in offer.excludes %}
        <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </div>

  <p><strong>{{ services.tax_residence | t(lang) }}</strong></p>
  <p class="price">{{ services.offers["en"][0].pricing | t(lang) | safe }}
  {{ services.efer | t(lang) | safe }}</p>
  <p>{{ services.vat_exempt | t(lang) }}</p>
  <a href="/{{ lang }}/contact" class="cta">{{ services.cta | t(lang) }}</a>
</section>

{% endfor %}
